# 基础配置
APP_NAME := api
BUILD_DIR := bin
CONFIG_FILE := etc/api.yaml
MIGRATE_SQL := migrations/001_init.sql
PG_CONTAINER := postgres
PG_DB_NAME := metaland
PG_USER := postgres

# 默认目标
.PHONY: all
all: build

# 开发模式：go run 直接跑
.PHONY: dev
dev:
	@echo "Running in development mode..."
	go run . -f $(CONFIG_FILE)

# 编译项目
.PHONY: build
build:
	@echo "Building $(APP_NAME)..."
	mkdir -p $(BUILD_DIR)
	go build -ldflags "-s -w" -o $(BUILD_DIR)/$(APP_NAME) .

# 编译后运行二进制
.PHONY: run
run: build
	@echo "Running $(APP_NAME) binary..."
	./$(BUILD_DIR)/$(APP_NAME) -f $(CONFIG_FILE)

# 数据库迁移：用docker执行psql，不用本地装psql
.PHONY: migrate
migrate:
	@echo "Running database migrations..."
	@docker cp $(MIGRATE_SQL) $(PG_CONTAINER):/tmp/migrate.sql
	@docker exec -i $(PG_CONTAINER) psql -U $(PG_USER) -d $(PG_DB_NAME) -f /tmp/migrate.sql
	@docker exec -i $(PG_CONTAINER) rm -f /tmp/migrate.sql
	@echo "✅ Migrate done"

# 整理依赖
.PHONY: tidy
tidy:
	go mod tidy
	go mod download

# 清理编译产物
.PHONY: clean
clean:
	@echo "Clean build files..."
	rm -rf $(BUILD_DIR)